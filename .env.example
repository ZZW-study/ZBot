# ZBot 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── LLM Provider API Keys ────────────────────────────────
# 至少配置一个 provider 的 API key

# OpenRouter (网关，支持多模型)
# OPENROUTER_API_KEY=sk-or-v1-...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# 阿里云 DashScope (通义千问)
# DASHSCOPE_API_KEY=sk-...

# 硅基流动 SiliconFlow
# SILICONFLOW_API_KEY=sk-...

# ── CORS 配置 ────────────────────────────────────────────
# 允许访问后端的域名（逗号分隔）
# 开发环境留空或设为 "*"，生产环境设为具体域名
# ZBOT_CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ── 其他配置 ─────────────────────────────────────────────
# 后端端口（默认 8000）
# ZBOT_BACKEND_PORT=8000

# 日志级别（默认 INFO）
# ZBOT_LOG_LEVEL=INFO
